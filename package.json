{
  "name": "daedalus-backend",
  "version": "1.0.5",
  "description": "TypeScript backend for the Godot Daedalus editor assistant plugin.",
  "main": "./src/main.ts",
  "bin": {
    "godot-daedalus-backend": "bin/godot-daedalus-backend.js",
    "godot-daedalus-manager": "bin/godot-daedalus-manager.js",
    "godot-daedalus-mcp": "bin/godot-daedalus-mcp.js",
    "godot-daedalus-terminal-mcp": "bin/godot-daedalus-terminal-mcp.js",
    "godot-daedalus-automation-mcp": "bin/godot-daedalus-automation-mcp.js"
  },
  "files": [
    "bin/",
    "docs/",
    "src/",
    "scripts/automation-smoke-matrix.ts",
    "scripts/beta-smoke.ps1",
    "scripts/llm-inline-diff-smoke.ts",
    "scripts/deepseek-tokenizer-server.py",
    "README.md"
  ],
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx src/main.ts",
    "ping": "tsx src/ping-client.ts",
    "mcp": "tsx src/mcp/external/server.ts",
    "terminal:mcp": "tsx src/mcp/terminal/server.ts",
    "automation:mcp": "tsx src/mcp/automation/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --import tsx --test \"tests/*.test.ts\"",
    "check": "npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "smoke:beta": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/beta-smoke.ps1",
    "smoke:llm": "tsx scripts/llm-inline-diff-smoke.ts",
    "smoke:automation": "tsx scripts/automation-smoke-matrix.ts",
    "dev:llm": "tsx scripts/llm-inline-diff-smoke.ts use_llm",
    "smoke:llm:full": "tsx scripts/llm-inline-diff-smoke.ts use_llm scenario=workflow_attach",
    "prepublishOnly": "npm test",
    "prepare": "husky",
    "commitlint": "commitlint --from=HEAD~10"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "godot",
    "editor-plugin",
    "mcp",
    "websocket",
    "deepseek"
  ],
  "author": "LuYingYiLong",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "keytar": "^7.9.0",
    "openai": "^6.45.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7"
  }
}
