[
  {
    "id": "deepseek",
    "displayName": "DeepSeek",
    "authType": "api-key",
    "defaultModel": "deepseek-v4-flash",
    "defaultEndpointType": "openai-chat-completions",
    "endpointConfigs": {
      "openai-chat-completions": {
        "baseUrl": "https://api.deepseek.com",
        "adapterFamily": "openai-compatible",
        "modelsPath": "/models"
      }
    },
    "envBaseUrl": "DEEPSEEK_BASE_URL",
    "envModel": "DEEPSEEK_MODEL"
  },
  {
    "id": "moonshot",
    "displayName": "Moonshot/Kimi",
    "authType": "api-key",
    "defaultModel": "kimi-k2.7-code",
    "defaultEndpointType": "openai-chat-completions",
    "endpointConfigs": {
      "openai-chat-completions": {
        "baseUrl": "https://api.moonshot.cn/v1",
        "adapterFamily": "openai-compatible",
        "modelsPath": "/models",
        "tokenEstimatePath": "/tokenizers/estimate-token-count",
        "requiredToolChoice": "omit",
        "temperature": { "min": 1, "max": 1 }
      }
    },
    "envBaseUrl": "MOONSHOT_BASE_URL",
    "envModel": "MOONSHOT_MODEL"
  },
  {
    "id": "openai",
    "displayName": "OpenAI",
    "authType": "api-key",
    "defaultModel": "gpt-5.5",
    "defaultEndpointType": "openai-responses",
    "endpointConfigs": {
      "openai-responses": {
        "baseUrl": "https://api.openai.com/v1",
        "adapterFamily": "openai-responses",
        "modelsPath": "/models"
      }
    },
    "envBaseUrl": "OPENAI_BASE_URL",
    "envModel": "OPENAI_MODEL"
  },
  {
    "id": "zhipu",
    "displayName": "Zhipu AI",
    "authType": "api-key",
    "defaultModel": "glm-5.2",
    "defaultEndpointType": "openai-chat-completions",
    "endpointConfigs": {
      "openai-chat-completions": {
        "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
        "adapterFamily": "openai-compatible",
        "modelsPath": "/models",
        "requiredToolChoice": "auto",
        "temperature": { "min": 0.01, "max": 1 }
      }
    },
    "envBaseUrl": "ZAI_BASE_URL",
    "envModel": "ZAI_MODEL"
  },
  {
    "id": "dashscope",
    "displayName": "Alibaba Cloud Qwen",
    "authType": "api-key",
    "defaultModel": "qwen-plus",
    "defaultEndpointType": "openai-chat-completions",
    "endpointConfigs": {
      "openai-chat-completions": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "adapterFamily": "openai-compatible",
        "modelsPath": "/models"
      }
    },
    "envBaseUrl": "DASHSCOPE_BASE_URL",
    "envModel": "DASHSCOPE_MODEL"
  }
]
